# ===========================
# PURBALINGGA SSO - ENV CONFIG
# ===========================

# App
NODE_ENV=development
PORT=4000
SSO_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5174

# Database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=purbalingga_sso
DB_USER=root
DB_PASS=

# Auto create database saat startup/seed
DB_AUTO_CREATE=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — Generate dengan: openssl genrsa -out private.pem 2048
# Lalu copy isi file tanpa newline, atau pakai format multiline
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
MIIEowIBAAKCAQEA...
-----END RSA PRIVATE KEY-----"

JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOC...
-----END PUBLIC KEY-----"

JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Email (pakai Mailtrap untuk dev)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM=noreply@purbalingga.id

# CORS (pisahkan dengan koma)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3001
